# Copy this file to .env and adjust local/sensitive values.
# .env is ignored by git.

# Android SDK / platform-tools
ANDROID_HOME=/home/$USER/android-sdk
ANDROID_SDK_ROOT=/home/$USER/android-sdk
ADB_BIN=/home/$USER/android-sdk/platform-tools/adb

# Java 21 is required by the Android build in this project.
JAVA_HOME=/home/$USER/.local/share/mise/installs/java/temurin-21

# Optional: pin one device if multiple phones/emulators are connected.
# Treat this as local/sensitive; keep it in .env, not committed.
# ADB_SERIAL=xxxxxxxx

# Debug APK defaults
GRADLE_TASK=assembleDebug
APK_PATH=android/app/build/outputs/apk/debug/app-debug.apk
APP_ID=dev.munchling.app
OPEN_AFTER_INSTALL=false
